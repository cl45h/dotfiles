#!/bin/sh
WALL_DIR="$HOME/pix/wall"

wall=$(find "$WALL_DIR" -maxdepth 1 -type f \( -iname "*.jpg" -o -iname "*.png" \) | sort | nsxiv -t -b -o -i 2>/dev/null | head -n 1)
[ -z "$wall" ] && exit 0

xwallpaper --output "DP-0" --zoom "$wall"

wal -c
wal -n -s -t -e -i "$wall"

xrdb -merge "$HOME/.cache/wal/colors.Xresources"

: "${FZF_DEFAULT_OPTS:=}"
: "${LS_COLORS:=}"

. "$HOME/.cache/wal/colors.sh"

cat > "$HOME/.cache/wal/dwm.Xresources" <<EOF
dwm.normbgcolor:          $background
dwm.normfgcolor:          $foreground
dwm.normbordercolor:      $color8
dwm.normfloatcolor:       $color8
dwm.selbgcolor:           $color1
dwm.selfgcolor:           $foreground
dwm.selbordercolor:       $color1
dwm.selfloatcolor:        $color1
dwm.titlenormbgcolor:     $background
dwm.titlenormfgcolor:     $foreground
dwm.titlenormbordercolor: $color8
dwm.titlenormfloatcolor:  $color8
dwm.titleselbgcolor:      $color1
dwm.titleselfgcolor:      $foreground
dwm.titleselbordercolor:  $color1
dwm.titleselfloatcolor:   $color1
dwm.tagsnormbgcolor:      $background
dwm.tagsnormfgcolor:      $foreground
dwm.tagsnormbordercolor:  $color8
dwm.tagsnormfloatcolor:   $color8
dwm.tagsselbgcolor:       $color1
dwm.tagsselfgcolor:       $foreground
dwm.tagsselbordercolor:   $color1
dwm.tagsselfloatcolor:    $color1
dwm.hidnormbgcolor:       $background
dwm.hidnormfgcolor:       $color8
dwm.hidselbgcolor:        $background
dwm.hidselfgcolor:        $color1
dwm.urgbgcolor:           $background
dwm.urgfgcolor:           $color3
EOF

xrdb -merge "$HOME/.cache/wal/dwm.Xresources"

xdotool key super+F5
